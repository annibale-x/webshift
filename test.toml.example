# test.toml — local integration test config (gitignored)
# Copy to test.toml and configure for your dev environment.
# Never commit API keys.

[server]
max_total_results = 5
max_query_budget = 16000
search_timeout = 10

[backends]
default = "searxng"

[backends.searxng]
enabled = true
url = "http://localhost:4000"

[backends.brave]
enabled = false
api_key = ""

[backends.tavily]
enabled = false
api_key = ""

[backends.exa]
enabled = false
api_key = ""

[backends.serpapi]
enabled = false
api_key = ""

[llm]
enabled = true
base_url = "http://localhost:11434/v1"
api_key = ""
model = "gemma3:27b"
